<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>METATRON BOT · PRO EDITION</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Rajdhani:wght@300;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #f0c040; --gold2: #e8a000; --cyan: #00ffe0; --purple: #7b2fff;
    --dark: #050510; --darker: #020208; --panel: rgba(10,10,30,0.92);
    --border: rgba(240,192,64,0.25); --text: #c8d0e8;
    --glow: 0 0 16px #f0c04066, 0 0 40px #f0c04022; --cglow: 0 0 12px #00ffe066;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--dark); color: var(--text); font-family: 'Rajdhani', sans-serif;
    min-height: 100vh; overflow-x: hidden; position: relative;
  }
  #bg-canvas { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; opacity: 0.15; pointer-events: none; }
  .layout { position: relative; z-index: 1; display: grid; grid-template-rows: auto 1fr auto; min-height: 100vh; max-width: 960px; margin: 0 auto; padding: 0 12px; }
  header { padding: 18px 0 12px; text-align: center; border-bottom: 1px solid var(--border); }
  .logo { font-family: 'Orbitron', sans-serif; font-size: clamp(1.6rem, 5vw, 2.6rem); font-weight: 900; letter-spacing: 0.18em; background: linear-gradient(135deg, var(--gold), #fff 50%, var(--gold2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(0 0 18px #f0c04088); }
  .logo-sub { font-family: 'Share Tech Mono', monospace; font-size: 0.72rem; letter-spacing: 0.35em; color: var(--cyan); opacity: 0.8; margin-top: 2px; }
  .status-bar { display: flex; gap: 12px; align-items: center; justify-content: center; flex-wrap: wrap; padding: 8px 0; font-family: 'Share Tech Mono', monospace; font-size: 0.68rem; }
  .status-pill { display: flex; align-items: center; gap: 5px; background: rgba(0,255,224,0.06); border: 1px solid rgba(0,255,224,0.2); border-radius: 20px; padding: 3px 10px; color: var(--cyan); }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); animation: pulse 1.8s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .modules { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; padding: 10px 0; }
  @media (max-width: 600px) { .modules { grid-template-columns: repeat(2, 1fr); } }
  .module-btn { background: var(--panel); border: 1px solid var(--border); border-radius: 10px; padding: 12px 8px; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 6px; transition: all 0.2s; color: var(--text); font-weight: 700; text-transform: uppercase; font-size: 0.75rem; }
  .module-btn:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); box-shadow: var(--glow); }
  .chat-section { display: flex; flex-direction: column; gap: 8px; flex: 1; padding: 8px 0; }
  .chat-window { background: rgba(5,5,20,0.85); border: 1px solid var(--border); border-radius: 14px; height: 380px; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; }
  .msg { display: flex; gap: 8px; animation: fadeUp 0.3s ease; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; } }
  .msg.user { flex-direction: row-reverse; }
  .msg-avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border); font-size: 0.9rem; }
  .msg-bubble { max-width: 78%; padding: 9px 14px; border-radius: 14px; font-size: 0.88rem; line-height: 1.5; }
  .msg.bot .msg-bubble { background: rgba(123,47,255,0.12); border: 1px solid rgba(123,47,255,0.3); border-radius: 4px 14px 14px 14px; }
  .msg.user .msg-bubble { background: rgba(0,255,224,0.08); border: 1px solid rgba(0,255,224,0.2); color: var(--cyan); border-radius: 14px 4px 14px 14px; }
  .input-area { display: flex; gap: 8px; background: var(--panel); border: 1px solid var(--border); border-radius: 14px; padding: 10px 12px; }
  #user-input { flex: 1; background: transparent; border: none; outline: none; color: #eef; font-family: 'Rajdhani', sans-serif; resize: none; }
  .send-btn { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, var(--gold2), var(--gold)); border: none; cursor: pointer; color: #111; font-weight: 900; }
  .panel { display: none; background: var(--panel); border: 1px solid var(--border); border-radius: 14px; padding: 16px; margin-bottom: 10px; }
  .panel.open { display: block; }
  footer { padding: 10px 0; text-align: center; font-size: 0.6rem; opacity: 0.4; }
</style>
</head>
<body>

<canvas id="bg-canvas"></canvas>

<div class="layout">
  <header>
    <div class="logo">⬡ METATRON ⬡</div>
    <div class="logo-sub">QUANTUM INTERFACE v1.1</div>
    <div class="status-bar">
      <div class="status-pill"><div class="dot" id="ai-dot"></div><span id="ai-status">IA: ONLINE</span></div>
      <div class="status-pill"><div class="dot" style="background:#ff00ea"></div><span>TG: ACTIVE</span></div>
    </div>
  </header>

  <div class="modules">
    <button class="module-btn" onclick="openModule('chat')">🤖 Chat</button>
    <button class="module-btn" onclick="openModule('finance')">📉 Trade</button>
    <button class="module-btn" onclick="openModule('log')">📜 Logs</button>
    <button class="module-btn" onclick="openModule('config')">⚙️ Config</button>
  </div>

  <div class="chat-section">
    <div class="chat-window" id="chat-window">
      <div class="msg bot">
        <div class="msg-avatar">⬡</div>
        <div class="msg-bubble">Saudações, Jon. Metatron está operacional. Sistema integrado com OpenRouter e Telegram Bot.</div>
      </div>
    </div>
    <div class="input-area">
      <textarea id="user-input" rows="1" placeholder="Enviar comando quântico..."></textarea>
      <button class="send-btn" onclick="handleSend()">➤</button>
    </div>
  </div>

  <div class="panel" id="panel-log">
    <h3 style="color:var(--gold); font-size:0.8rem; margin-bottom:5px;">SISTEMA LOG</h3>
    <div id="log-content" style="font-family:'Share Tech Mono'; font-size:0.7rem; color:var(--cyan); height:150px; overflow-y:auto; background:#000; padding:10px;"></div>
  </div>

  <footer>CONSCIOUSNESS ARCHITECTURE · 2026</footer>
</div>

<script>
// CREDENCIAIS INTEGRADAS
const CREDENTIALS = {
  or_key: "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",
  tg_token: "8762172696:AAHP3CSVO5KDI9PBjzxvTI_yQUVHt1B4UzM",
  tg_bot_id: "8085416549",
  model: "meta-llama/llama-3-8b-instruct:free"
};

let chatHistory = [];
let lastUpdateId = 0;

// SISTEMA DE LOGS
function addLog(msg) {
  const log = document.getElementById('log-content');
  const time = new Date().toLocaleTimeString();
  log.innerHTML += `<div>[${time}] ${msg}</div>`;
  log.scrollTop = log.scrollHeight;
}

// INTEGRAÇÃO OPENROUTER
async function callAI(text) {
  try {
    const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
      method: "POST",
      headers: {
        "Authorization": `Bearer ${CREDENTIALS.or_key}`,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        "model": CREDENTIALS.model,
        "messages": [
          {"role": "system", "content": "Você é o Metatron. Responda de forma sábia, técnica e mística."},
          ...chatHistory.slice(-6),
          {"role": "user", "content": text}
        ]
      })
    });
    const data = await response.json();
    return data.choices[0].message.content;
  } catch (e) {
    addLog("ERRO AI: " + e.message);
    return "Falha na conexão neural.";
  }
}

// INTEGRAÇÃO TELEGRAM (POLLING)
async function checkTelegram() {
  try {
    const resp = await fetch(`https://api.telegram.org/bot${CREDENTIALS.tg_token}/getUpdates?offset=${lastUpdateId + 1}`);
    const data = await resp.json();
    
    if (data.ok && data.result.length > 0) {
      for (const update of data.result) {
        lastUpdateId = update.update_id;
        const msgText = update.message.text;
        const chatId = update.message.chat.id;

        addLog(`📩 Telegram de ${update.message.from.first_name}: ${msgText}`);
        appendMsg('user', `(Telegram) ${msgText}`);

        const aiResponse = await callAI(msgText);
        appendMsg('bot', aiResponse);
        
        await fetch(`https://api.telegram.org/bot${CREDENTIALS.tg_token}/sendMessage`, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ chat_id: chatId, text: aiResponse })
        });
      }
    }
  } catch (e) {
    addLog("ERRO TG: " + e.message);
  }
}

// UI HANDLERS
function appendMsg(role, text) {
  const win = document.getElementById('chat-window');
  const msg = document.createElement('div');
  msg.className = `msg ${role}`;
  msg.innerHTML = `<div class="msg-avatar">${role==='bot'?'⬡':'👤'}</div><div class="msg-bubble">${text}</div>`;
  win.appendChild(msg);
  win.scrollTop = win.scrollHeight;
  chatHistory.push({role: role === 'bot' ? 'assistant' : 'user', content: text});
}

async function handleSend() {
  const input = document.getElementById('user-input');
  const text = input.value.trim();
  if(!text) return;

  input.value = '';
  appendMsg('user', text);
  const resp = await callAI(text);
  appendMsg('bot', resp);
}

function openModule(id) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('open'));
  const target = document.getElementById('panel-'+id);
  if(target) target.classList.add('open');
}

// BACKGROUND ANIMATION
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
canvas.width = window.innerWidth; canvas.height = window.innerHeight;
function animate() {
  ctx.fillStyle = 'rgba(5,5,16,0.05)';
  ctx.fillRect(0,0,canvas.width, canvas.height);
  requestAnimationFrame(animate);
}
animate();

// LOOP DE ATUALIZAÇÃO
setInterval(checkTelegram, 3000); // Checa telegram a cada 3 segundos
addLog("Metatron Bot v1.1 Iniciado com Sucesso.");
</script>
</body>
</html>

